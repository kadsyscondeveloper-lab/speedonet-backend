# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── SQL Server ────────────────────────────────────────────────────────────────
DB_SERVER=103.88.81.5
DB_PORT=1433
DB_NAME=broadbanddb
DB_USER=sa
DB_PASSWORD=your_password_here
DB_ENCRYPT=true
DB_TRUST_CERT=true

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_min_64_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── OTP ───────────────────────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6
# Set to 'true' in dev so OTP is always 123456 (skip real SMS)
OTP_BYPASS_DEV=true

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ── Bcrypt ────────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
